# Gmail SMTP credentials
# You need a Gmail App Password (not your regular password)
# Go to: Google Account > Security > 2-Step Verification > App Passwords
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# Recipient email
EMAIL_TO=recipient@example.com

# Origin airport (default: TLV)
ORIGIN=TLV

# Destination: "europe" for all European airports, or comma-separated codes
# Examples: europe, BCN,ATH,FCO, LHR
DESTINATION=europe

# Trip type: "oneway" or "roundtrip"
TRIP_TYPE=oneway

# Outbound date range (YYYY-MM-DD)
OUTBOUND_FROM=2026-04-01
OUTBOUND_TO=2026-04-15

# Return date range (only required if TRIP_TYPE=roundtrip)
# RETURN_FROM=2026-04-10
# RETURN_TO=2026-04-20

# Stops filter: "any", "nonstop", or a number like "1" for max 1 stop (default: any)
STOPS=any

# Search providers: comma-separated list (default: google,skyscanner)
# Options: google, skyscanner
PROVIDERS=google,skyscanner

# Set to false to see the browser during development
HEADLESS=true
